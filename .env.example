# Webhook security
WEBHOOK_SECRET=replace-with-a-long-random-secret

# Google OAuth files. Used for Gmail and, when selected, Google Drive storage.
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
# For Render, paste JSON contents into env vars instead of relying on local files.
GOOGLE_CREDENTIALS_JSON=
GOOGLE_TOKEN_JSON=

# Airtable
AIRTABLE_TOKEN=pat_xxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appxxxxxxxxxxxxxx
AIRTABLE_TABLE_NAME=Drawings

# Airtable field names. Change these if your base uses different names.
AIRTABLE_FIELD_CUSTOMER_EMAIL=Customer Email
AIRTABLE_FIELD_EMAIL_SUBJECT=Email Subject
AIRTABLE_FIELD_RECEIVED_DATE=Received Date
AIRTABLE_FIELD_FILE_NAME=File Name
AIRTABLE_FIELD_FILE_TYPE=File Type
AIRTABLE_FIELD_ORIGINAL_FILE_LINK=Original File Link
# url = store the Google Drive/local link as text/URL.
# attachment = write Airtable attachment array. Requires a public/reachable URL.
AIRTABLE_FIELD_ORIGINAL_FILE_KIND=url
AIRTABLE_FIELD_FILE_HASH=File Hash
AIRTABLE_FIELD_GEOMETRY_FINGERPRINT=Geometry Fingerprint
AIRTABLE_FIELD_DRAWING_CODE=Drawing Code / Product Code
AIRTABLE_FIELD_STATUS=Status
AIRTABLE_FIELD_DUPLICATE_MATCH_RECORD=Duplicate Match Record
AIRTABLE_FIELD_DIFFERENCE_SUMMARY=Difference Summary
AIRTABLE_FIELD_NOTES=Notes
AIRTABLE_FIELD_GEOMETRY_SUMMARY=Geometry Summary JSON

# Storage backend: google_drive or local.
# Use google_drive for Render/free production because Render local files are temporary.
STORAGE_BACKEND=google_drive
STORAGE_DIR=storage
PUBLIC_FILE_BASE_URL=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_SHARE_FILES=false

# Optional DWG conversion. Leave blank for free-first deployments unless you install a free converter.
# Use a command template that writes a DXF into {output_dir}.
# Example for ODA File Converter varies by install path and OS.
DWG_CONVERTER_COMMAND=

# Notification mode: none, gmail, slack, telegram
NOTIFICATION_MODE=gmail
NOTIFICATION_EMAIL_TO=you@example.com
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Fingerprinting behavior
GEOMETRY_ROUND_PRECISION=4
LOW_CONFIDENCE_MAX_UNSUPPORTED_RATIO=0.50
